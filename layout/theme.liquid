        if (overlay) {
          overlay.classList.remove("bg-transparent");
          overlay.classList.add("bg-[#282C3780]");
        }
      } else {
        this.classList.add("selected");
        this.classList.remove("bg-[#2F333D]", "hover:bg-[#4A4E5A]", "text-white");
        this.classList.add("bg-[#FFFFFF]", "text-[#282C37]");

        if (overlay) {
          overlay.classList.remove("bg-[#282C3780]");
          overlay.classList.add("bg-transparent");
        }
      }
    });
  });

  // Image hover effects for unselected cards only
  configOptions.forEach((option) => {
    const img = option.querySelector("img[data-hover-src]");
    if (img) {
      const originalSrc = img.src;
      const hoverSrc = img.getAttribute("data-hover-src");

      option.addEventListener("mouseenter", function () {
        if (!this.classList.contains("selected")) {
          img.src = hoverSrc;
        }
      });

      option.addEventListener("mouseleave", function () {
        if (!this.classList.contains("selected")) {
          img.src = originalSrc;
        }
      });
    }
  });

  // Build and Calibration Button Functionality
  const buildOptions = document.querySelectorAll(".build-option");
  const buildSelectedText = document.getElementById("build-selected-text");

  buildOptions.forEach((button) => {
    button.addEventListener("click", function () {
      buildOptions.forEach((btn) => {
        btn.classList.remove("bg-[#ffffff]", "text-[#2F333D]");
        btn.classList.add("bg-[#2F333D]", "text-white", "hover:bg-[#4A4E5A]");
      });

      this.classList.remove("bg-[#2F333D]", "text-white", "hover:bg-[#4A4E5A]");
      this.classList.add("bg-[#ffffff]", "text-[#2F333D]");

      if (buildSelectedText) {
        buildSelectedText.textContent = this.getAttribute("data-value");
      }
    });
  });

  /* -----------------------------------------------------------
     FIXED QUANTITY SELECTOR (NO double triggers)
  ----------------------------------------------------------- */
  const qtyText = document.getElementById("quantity-text");
  const qtyDecrease = document.getElementById("qty-decrease");
  const qtyIncrease = document.getElementById("qty-increase");

  // Ensures consistent quantity tracking
  let quantity = parseInt(qtyText.textContent) || 1;

  function updateQty() {
    qtyText.textContent = quantity;
  }

  if (qtyDecrease) {
    qtyDecrease.addEventListener("click", function () {
      if (quantity > 1) {
        quantity -= 1;
        updateQty();
      }
    });
  }

  if (qtyIncrease) {
    qtyIncrease.addEventListener("click", function () {
      quantity += 1;
      updateQty();
    });
  }
});
