        <script>
      document.addEventListener("DOMContentLoaded", function () {
        // Filter Button Functionality
        const filterButtons = document.querySelectorAll(
          'button[class*="px-[24px] py-[12px]"]'
        );

        filterButtons.forEach((button) => {
          button.addEventListener("click", function () {
            // Remove active state from all buttons
            filterButtons.forEach((btn) => {
              btn.classList.remove("bg-white", "text-[#1C2127]");
              btn.classList.add("bg-[#2F333D]", "text-white");
            });

            // Add active state to clicked button
            this.classList.remove("bg-[#2F333D]", "text-white");
            this.classList.add("bg-white", "text-[#1C2127]");
          });
        });

        // Pagination Functionality
        const articlesContainer = document.querySelector(".articles-container");
        const articles = document.querySelectorAll(".article-card");
        const prevBtn = document.getElementById("prev-btn");
        const nextBtn = document.getElementById("next-btn");
        const page1Btn = document.getElementById("page-1");
        const page2Btn = document.getElementById("page-2");
        const page3Btn = document.getElementById("page-3");

        let currentPage = 1; // Start on page 1 as it's active
        const articlesPerPage = 8;
        const totalPages = Math.ceil(articles.length / articlesPerPage);

        function showPage(page) {
          // Hide all articles
          articles.forEach((article) => {
            article.style.display = "none";
          });

          // Show articles for current page
          const startIndex = (page - 1) * articlesPerPage;
          const endIndex = startIndex + articlesPerPage;

          for (let i = startIndex; i < endIndex && i < articles.length; i++) {
            articles[i].style.display = "block";
          }

          // Update pagination buttons
          updatePaginationButtons(page);
        }

        function updatePaginationButtons(activePage) {
          // Remove active state from all page buttons
          [page1Btn, page2Btn, page3Btn].forEach((btn) => {
            btn.classList.remove("bg-[#6EC7B3]");
            btn.classList.add("text-white");
          });

          // Add active state to current page button
          const activeBtn = document.getElementById(`page-${activePage}`);
          if (activeBtn) {
            activeBtn.classList.remove("text-white");
            activeBtn.classList.add("bg-[#6EC7B3]");
          }

          // Disable page buttons that have no articles
          [page1Btn, page2Btn, page3Btn].forEach((btn, index) => {
            const pageNumber = index + 1;
            const startIndex = (pageNumber - 1) * articlesPerPage;
            const hasArticles = startIndex < articles.length;

            if (hasArticles) {
              btn.disabled = false;
              btn.classList.remove("opacity-50", "cursor-not-allowed");
              btn.classList.add("cursor-pointer");
            } else {
              btn.disabled = true;
              btn.classList.add("opacity-50", "cursor-not-allowed");
              btn.classList.remove("cursor-pointer");
            }
          });

          // Update prev/next button states
          prevBtn.disabled = activePage === 1;
          nextBtn.disabled = activePage === totalPages;
        }

        // Event listeners
        prevBtn.addEventListener("click", () => {
          if (currentPage > 1) {
            currentPage--;
            showPage(currentPage);
          }
        });

        nextBtn.addEventListener("click", () => {
          if (currentPage < totalPages) {
            currentPage++;
            showPage(currentPage);
          }
        });

        page1Btn.addEventListener("click", () => {
          if (!page1Btn.disabled) {
            currentPage = 1;
            showPage(currentPage);
          }
        });

        page2Btn.addEventListener("click", () => {
          if (!page2Btn.disabled) {
            currentPage = 2;
            showPage(currentPage);
          }
        });

        page3Btn.addEventListener("click", () => {
          if (!page3Btn.disabled) {
            currentPage = 3;
            showPage(currentPage);
          }
        });

        // Initialize pagination
        showPage(currentPage);
      });
    </script>
  </body>
