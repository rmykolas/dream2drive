    "dd_faqs_QDtgac": {
      "type": "dd-faqs",
      "blocks": {
        "faq_T7rzVH": {
          "type": "faq",
          "settings": {
            "question": "Who supervises BeMyBond's activities? What license does this platform have?",
            "answer": "The activities of the BeMyBond bond platform are supervised by the Bank of Lithuania. The platform has a crowdfunding service provider license granted by the European Union Crowdfunding Regulation 2020/1503. The license allows to act as a crowdfunding service provider in all European Union member states according to the system established by the regulation. The regulation ensures equal investor protection and transparency in all member states and meets the high standards of the European Union. License number: No.13, date of issue: 16.04.2024."
          }
        },
        "faq_nb4p8Q": {
          "type": "faq",
          "settings": {
            "question": "What is the Know Your Customer (KYC) principle and why is it necessary?",
            "answer": "KYC (Know Your Customer) is a regulatory requirement that helps verify the identity of customers to prevent fraud, money laundering, and other illegal activities. It's necessary to ensure compliance with financial regulations and protect both the platform and its users."
          }
        },
        "faq_C4Jf6w": {
          "type": "faq",
          "settings": {
            "question": "Do I get an investment account?",
            "answer": "Yes, when you register on our platform, you will automatically receive an investment account that allows you to browse, select, and invest in various racing-related projects and opportunities."
          }
        },
        "faq_4jkVwe": {
          "type": "faq",
          "settings": {
            "question": "Do I need to have a securities account before starting to invest on BeMyBond?",
            "answer": "No, you don't need a separate securities account. Our platform provides everything you need to start investing immediately after completing the registration and verification process."
          }
        },
        "faq_UhNgjn": {
          "type": "faq",
          "settings": {
            "question": "How can I find out about the latest BeMyBond bonds issues?",
            "answer": "You can stay updated on the latest bond issues by subscribing to our newsletter, following our social media channels, or regularly checking the platform's investment opportunities section."
          }
        },
        "faq_i3DHYP": {
          "type": "faq",
          "settings": {
            "question": "Can I cancel my investment?",
            "answer": "Investment cancellation policies vary depending on the specific project and its terms. Please review the individual project details and contact our support team for specific cancellation policies."
          }
        }
      },
