{% comment %} <script>
document.addEventListener("DOMContentLoaded", () => {
  const atcBtn = document.getElementById("atc_btn");
  const qtyText = document.getElementById("quantity-text");
  const priceDisplay = document.querySelector(".product-price");

  if (!atcBtn || !qtyText || !priceDisplay) return;

  // -------------------
  // Quantity logic
  // -------------------
  let quantity = parseInt(qtyText.textContent.trim()) || 1;

  const updateQtyText = () => {
    qtyText.textContent = quantity;
    updateTotalPrice();
  };

  const qtyIncrease = document.getElementById("qty-increase");
  const qtyDecrease = document.getElementById("qty-decrease");

  qtyIncrease?.addEventListener("click", () => {
    quantity += 1;
    updateQtyText();
  });

  qtyDecrease?.addEventListener("click", () => {
    if (quantity > 1) {
      quantity -= 1;
      updateQtyText();
    }
  });

  // -------------------
  // Variant selection logic (allowing multiple selection)
  // -------------------
  const selectedVariants = new Set(); // Track selected variants

  document.querySelectorAll(".product-options").forEach((option) => {
    option.addEventListener("click", () => {
      const variantId = parseInt(option.dataset.variantId);
      
      // Toggle the selection of the option
      if (selectedVariants.has(variantId)) {
        selectedVariants.delete(variantId); // Deselect
        option.classList.remove("selected");
      } else {
        selectedVariants.add(variantId); // Select
        option.classList.add("selected");
      }

      updateTotalPrice();
    });
  });

  // -------------------
  // Price calculation
  // -------------------
  const mainPrice = {{ product.price | divided_by: 100 }};

  function updateTotalPrice() {
    const totalChildPrice = [...selectedVariants].reduce((sum, variantId) => {
      const variantOption = document.querySelector(`.product-options[data-variant-id="${variantId}"]`);
      const price = parseFloat(variantOption?.dataset.price || "0");
      return sum + price;
    }, 0);

    const total = (mainPrice + totalChildPrice) * quantity;
    priceDisplay.textContent = `£${total.toFixed(2)}`;
  }

  updateTotalPrice(); // Initialize

  // -------------------
  // Add to Cart logic
  // -------------------
  atcBtn.addEventListener("click", async () => {
    if (selectedVariants.size === 0) {
      alert("Please select at least one variant before adding to cart.");
      return;
    }

    const mainVariantId = {{ product.selected_or_first_available_variant.id }};
    const mainProductTitle = `{{ product.title | escape }}`;

    // Build the items array: main product + selected variants
    const items = [
      // Main product (the parent)
      {
        id: mainVariantId,
        quantity: quantity,
        properties: {}  // No special properties for the main product
      },
      // Selected variants (children)
      ...[...selectedVariants].map(variantId => {
        const option = document.querySelector(`.product-options[data-variant-id="${variantId}"]`);
        return {
          id: variantId,
          quantity: quantity,
          properties: {
            _child_of: mainVariantId  // Link the variant to the main product
          }
        };
      })
    ];

    try {
      const response = await fetch("/cart/add.js", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ items })
      });

      const data = await response.json();
      console.log("Cart add response:", data);

      if (!response.ok) throw new Error(data.message || "Failed to add items to cart");

      window.location.href = "/cart"; // Redirect to cart page
    } catch (error) {
      console.error("Error adding to cart:", error);
      alert("There was an error adding your items to the cart: " + error.message);
    }
  });
});
</script> {% endcomment %}
<script>
(function() {
  'use strict';
  
  document.addEventListener("DOMContentLoaded", function() {
    // Get elements
    const atcBtn = document.getElementById("atc_btn");
    const qtyText = document.getElementById("quantity-text");
    const qtyIncrease = document.getElementById("qty-increase");
    const qtyDecrease = document.getElementById("qty-decrease");
    const priceDisplays = document.querySelectorAll(".product-price");
    const variantContainer = document.getElementById("varaint-custom");
    
    if (!atcBtn || !qtyText || priceDisplays.length === 0) return;
    
    // State
    let quantity = parseInt(qtyText.textContent.trim()) || 1;
    let selectedVariantId = null;
    const mainPrice = {{ product.price | divided_by: 100 }};
    
    // Format price function
    function formatPrice(amount) {
      return '€' + amount.toFixed(2).replace('.', ',') + ' EUR';
    }
    
    // Update price display
    function updatePrice() {
      let total;
      
      if (selectedVariantId) {
        const selectedOption = document.querySelector('.product-options[data-variant-id="' + selectedVariantId + '"]');
        if (selectedOption) {
          const variantPrice = parseFloat(selectedOption.getAttribute('data-price')) || 0;
          total = variantPrice * quantity;
        } else {
          total = mainPrice * quantity;
        }
      } else {
        total = mainPrice * quantity;
      }
      
      const formattedPrice = formatPrice(total);
      for (let i = 0; i < priceDisplays.length; i++) {
        priceDisplays[i].textContent = formattedPrice;
      }
    }
    
    // Quantity handlers
    if (qtyIncrease) {
      qtyIncrease.addEventListener('click', function(e) {
        e.preventDefault();
        quantity += 1;
        qtyText.textContent = quantity;
        updatePrice();
      });
    }
    
    if (qtyDecrease) {
      qtyDecrease.addEventListener('click', function(e) {
        e.preventDefault();
        if (quantity > 1) {
          quantity -= 1;
          qtyText.textContent = quantity;
          updatePrice();
        }
      });
    }
    
    // Variant selection - single selection only
    // Attach directly to each option to avoid conflicts
    const allVariantOptions = document.querySelectorAll('.product-options');
    
    function selectVariant(variantId, clickedOption) {
      // First, deselect ALL options
      for (let i = 0; i < allVariantOptions.length; i++) {
        allVariantOptions[i].classList.remove('selected');
      }
      
      // Then select the clicked one
      selectedVariantId = variantId;
      if (clickedOption) {
        clickedOption.classList.add('selected');
      }
      
      // Update price
      updatePrice();
      
      // Update URL
      const url = new URL(window.location.href);
      url.searchParams.set('variant', selectedVariantId);
      window.history.pushState({}, '', url);
    }
    
    // Attach click handler to each option
    for (let i = 0; i < allVariantOptions.length; i++) {
      allVariantOptions[i].addEventListener('click', function(e) {
        e.preventDefault();
        e.stopPropagation();
        e.stopImmediatePropagation();
        
        const variantId = parseInt(this.getAttribute('data-variant-id'));
        if (isNaN(variantId)) return;
        
        // If same variant clicked, deselect it
        if (selectedVariantId === variantId) {
          // Deselect all options
          for (let j = 0; j < allVariantOptions.length; j++) {
            allVariantOptions[j].classList.remove('selected');
          }
          selectedVariantId = null;
          
          // Update price
          updatePrice();
          
          // Update URL - remove variant parameter
          const url = new URL(window.location.href);
          url.searchParams.delete('variant');
          window.history.pushState({}, '', url);
          
          return;
        }
        
        // Select this variant
        selectVariant(variantId, this);
      });
    }
    
    // Add to cart
    atcBtn.addEventListener('click', async function(e) {
      e.preventDefault();
      
      // Use selected variant or default to first available variant
      const variantIdToAdd = selectedVariantId || {{ product.selected_or_first_available_variant.id }};
      
      try {
        const response = await fetch('/cart/add.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            id: variantIdToAdd,
            quantity: quantity
          })
        });
        
        const data = await response.json();
        
        if (!response.ok) {
          throw new Error(data.message || 'Failed to add item to cart');
        }
        
        window.location.href = '/cart';
      } catch (error) {
        console.error('Error adding to cart:', error);
        alert('There was an error adding your item to the cart: ' + error.message);
      }
    });
    
    // Initialize price
    updatePrice();
  });
})();
</script>

<script>
document.addEventListener("DOMContentLoaded", () => {
  const thumbnails = document.querySelectorAll(".product-thumbnail");
  const desktopImage = document.getElementById("product-image-desktop");
  const mobileImage = document.getElementById("product-image-mobile");

  if (thumbnails.length === 0) return;

  thumbnails.forEach((thumbnail) => {
    thumbnail.addEventListener("click", () => {
      const imageSrc = thumbnail.dataset.imageSrc;
      const imageAlt = thumbnail.dataset.imageAlt;

      // Update desktop image
      if (desktopImage) {
        desktopImage.src = imageSrc;
        desktopImage.alt = imageAlt;
      }

      // Update mobile image
      if (mobileImage) {
        mobileImage.src = imageSrc;
        mobileImage.alt = imageAlt;
      }

      // Update active thumbnail border
      thumbnails.forEach((thumb) => {
        thumb.classList.remove("border-[#6EC7B3]");
        thumb.classList.add("border-transparent");
      });
      thumbnail.classList.remove("border-transparent");
      thumbnail.classList.add("border-[#6EC7B3]");
    });
  });
});
</script>