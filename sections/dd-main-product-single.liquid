<div class="hidden lg:block lg:fixed lg:top-[147px] lg:left-[50%] lg:-translate-x-[50%] lg:w-full lg:max-w-[1440px] z-[1] pointer-events-none font-roboto-condensed">
      <div class="max-w-[50%] flex gap-[16px]">
            <!-- Desktop Thumbnails (Left Side) -->
            {% if product.media.size > 1 %}
            <div class="flex flex-col gap-[8px] pointer-events-auto max-h-[500px] overflow-y-auto">
              {% for media in product.media %}
                {% if media.media_type == 'image' %}
                  <button
                    class="product-thumbnail w-[80px] h-[80px] border-2 border-transparent hover:border-[#6EC7B3] transition-all duration-300 overflow-hidden bg-[#2F333D] flex-shrink-0 {% if forloop.first %}border-[#6EC7B3]{% endif %}"
                    data-image-src="{{ media | image_url: width: 800 }}"
                    data-image-alt="{{ media.alt | escape }}"
                  >
                    <img src="{{ media | image_url: width: 160 }}" alt="{{ media.alt | escape }}" class="w-full h-full object-contain"/>
                  </button>
                {% endif %}
              {% endfor %}
            </div>
            {% endif %}
            <!-- Desktop Main Image -->
            <div class="p-[40px] flex items-center justify-center overflow-hidden pointer-events-auto flex-1">
                <img id="product-image-desktop" src="{{ product.featured_image | image_url: width: 800 }}" alt="{{ product.title }}" class="w-[610px] h-auto object-contain"/>
            </div>
      </div>
</div>
