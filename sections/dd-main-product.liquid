<div class="hidden lg:block lg:fixed lg:top-[147px] lg:left-[50%] lg:-translate-x-[50%] lg:w-full lg:max-w-[1440px] z-[1] pointer-events-none font-roboto-condensed">
      <div class="max-w-[50%] flex gap-[16px]">
            <!-- Desktop Thumbnails (Left Side) -->
            {% if product.media.size > 1 %}
            <div class="flex flex-col gap-[8px] pointer-events-auto max-h-[500px] overflow-y-auto">
              {% for media in product.media %}
                {% if media.media_type == 'image' %}
                  <button
                    class="product-thumbnail w-[80px] h-[80px] border-2 border-transparent hover:border-[#6EC7B3] transition-all duration-300 overflow-hidden bg-[#2F333D] flex-shrink-0 {% if forloop.first %}border-[#6EC7B3]{% endif %}"
                    data-image-src="{{ media | image_url: width: 800 }}"
                    data-image-alt="{{ media.alt | escape }}"
                  >
                    <img src="{{ media | image_url: width: 160 }}" alt="{{ media.alt | escape }}" class="w-full h-full object-contain"/>
                  </button>
                {% endif %}
              {% endfor %}
            </div>
            {% endif %}
            <!-- Desktop Main Image -->
            <div class="p-[40px] flex items-center justify-center overflow-hidden pointer-events-auto flex-1">
                <img id="product-image-desktop" src="{{ product.featured_image | image_url: width: 800 }}" alt="{{ product.title }}" class="w-[610px] h-auto object-contain"/>
            </div>
      </div>
</div>
<!-- Product Section -->
<section class="bg-[#ECECEC] relative font-roboto-condensed lg:z-0">
  <div class="w-full">
    <div class="flex flex-col lg:flex-row gap-[60px]">
      <!-- Left Side - Product Image (Mobile Only) -->
      <div class="lg:hidden">
        <div class="bg-[#1C2127] px-[15px] md:px-[24px] md:py-[32px] py-[24px]">
          <!-- Breadcrumb -->
          <div class="flex items-center flex-wrap gap-[18px] mb-[24px]">
                <a href="{{ routes.root_url }}" class="hover:text-[#6EC7B3] transition-colors text-[14px] font-normal text-[#C8C9CC]">Home</a>
                <img src="https://cdn.shopify.com/s/files/1/0976/8622/5226/files/right_arrow-white.svg?v=1761556170" alt="" class="w-[10px] h-[10px]"/>
                {% assign product_collection = collection | default: product.collections.first %}
                {% if product_collection %}
                    <a href="{{ product_collection.url }}" class="hover:text-[#6EC7B3] transition-colors text-[14px] font-normal text-[#C8C9CC]">{{ product_collection.title }}</a>
                    <img src="https://cdn.shopify.com/s/files/1/0976/8622/5226/files/right_arrow-white.svg?v=1761556170" alt="" class="w-[10px] h-[10px]"/>
                {% endif %}
                <a href="{{ product.url }}" class="hover:text-[#6EC7B3] transition-colors text-[14px] font-normal text-[#C8C9CC]">{{ product.title }}</a>
            </div>
          <!-- Product Title -->
          <h2 class="text-[40px] sm:text-[52px] font-bold text-white mb-[2px] leading-[100%]">{{ product.title }}</h2>
          <!-- Price -->
          <div>
            <p class="product-price text-[16px] sm:text-[20px] font-normal text-[#C8C9CC]">
              {{ product.price | money_with_currency }}{% if product.compare_at_price_max > product.price %} – {{ product.compare_at_price_max | money_with_currency }}{% endif %}
            </p>
          </div>
        </div>
        <!-- Mobile Image -->
        <div class="p-[40px] flex items-center justify-center overflow-hidden">
          <img id="product-image-mobile" src="{{ product.featured_image | image_url: width: 800 }}" alt="{{ product.title }}" class="w-full h-auto max-h-[600px] object-contain"/>
        </div>
        <!-- Mobile Thumbnails (Bottom) -->
        {% if product.media.size > 1 %}
        <div class="px-[40px] flex gap-[8px] overflow-x-auto">
          {% for media in product.media %}
            {% if media.media_type == 'image' %}
              <button
                class="product-thumbnail flex-shrink-0 w-[80px] h-[80px] border-2 border-transparent hover:border-[#6EC7B3] transition-all duration-300 overflow-hidden bg-[#2F333D] {% if forloop.first %}border-[#6EC7B3]{% endif %}"
                data-image-src="{{ media | image_url: width: 800 }}"
                data-image-alt="{{ media.alt | escape }}"
              >
                <img src="{{ media | image_url: width: 160 }}" alt="{{ media.alt | escape }}" class="w-full h-full object-contain"/>
              </button>
            {% endif %}
          {% endfor %}
        </div>
        {% endif %}
      </div>
      <!-- Spacer for Desktop -->
      <div class="hidden lg:block lg:flex-1"></div>
      <!-- Right Side - Product Information -->
      <div class="bg-[#1C2127] px-[15px] md:px-[24px] pt-[32px] md:pt-[80px] pb-[32px] text-white relative z-[1] lg:flex-1">
        <div class="max-w-[576px] max-lg:mx-auto">
            <div class="max-lg:hidden">
                <!-- Breadcrumb -->
                <div class="flex items-center flex-wrap gap-[18px] mb-[24px]">
                    <a
                        href="{{ routes.root_url }}"
                        class="hover:text-[#6EC7B3] transition-colors text-[14px] font-normal text-[#C8C9CC]"
                    >Home</a>
                    <img
                        src="https://cdn.shopify.com/s/files/1/0976/8622/5226/files/right_arrow-white.svg?v=1761556170"
                        alt=""
                        class="w-[10px] h-[10px]"
                    />

                    {% assign product_collection = collection | default: product.collections.first %}
                    {% if product_collection %}
                        <a href="{{ product_collection.url }}" class="hover:text-[#6EC7B3] transition-colors text-[14px] font-normal text-[#C8C9CC]">{{ product_collection.title }}</a>
                        <img
                        src="https://cdn.shopify.com/s/files/1/0976/8622/5226/files/right_arrow-white.svg?v=1761556170"
                        alt=""
                        class="w-[10px] h-[10px]"
                        />
                    {% endif %}

                    <a href="{{ product.url }}" class="hover:text-[#6EC7B3] transition-colors text-[14px] font-normal text-[#C8C9CC]">{{ product.title }}</a>
                </div>
                <!-- Product Title -->
                <h2 class="text-[52px] font-bold text-white mb-[2px] leading-[100%]">{{ product.title }}</h2>
                <!-- Price -->
                <div class="mb-[24px] pb-[24px] border-b border-[#C8C9CC]">
                <p class="product-price text-[20px] font-normal text-[#C8C9CC]">
                    {{ product.price | money_with_currency }}{% if product.compare_at_price_max > product.price %} – {{ product.compare_at_price_max | money_with_currency }}{% endif %}
                </p>
                </div>
            </div>
         <!-- Configuration Options -->
            <div class="space-y-[24px]">
                {% for block in section.blocks %}
                    {% assign product_handle = block.settings.linked_product %}
                    {% assign linked_product = all_products[product_handle] %}
                    {% if linked_product %}
                        <div>
                            <!-- Title + Subtitle -->
                            <div class="flex items-center gap-[6px] mb-[10px]">
                            <p class="text-[18px] font-medium">{{ block.settings.title }}</p>
                            {% if block.settings.subtitle != blank %}
                                <p class="text-[14px] font-normal text-[#C8C9CC]">{{ block.settings.subtitle }}</p>
                            {% endif %}
                            </div>

                            <!-- Variant Options -->
                            <div class="flex flex-wrap gap-[8px]">
                            {% for variant in linked_product.variants %}
                                <div
                                class="product-options cursor-pointer flex items-center max-w-[284px] w-full h-[88px] bg-[#2F333D] hover:bg-[#4A4E5A] text-white group transition-all duration-300"
                                data-variant-id="{{ variant.id }}"
                                data-product-handle="{{ linked_product.handle }}"
                                data-price="{{ variant.price | divided_by: 100 }}"
                                >
                                <div
                                    class="option-image-bg bg-[#C8C9CC] h-full min-w-[88px] relative flex items-center justify-center transition-all duration-300"
                                >
                                    {% if variant.featured_image %}
                                    <img
                                        src="{{ variant.featured_image | img_url: '300x300' }}"
                                        alt="{{ variant.title }}"
                                        class="w-full h-full object-contain"
                                    />
                                    {% else %}
                                    <img
                                        src="{{ linked_product.featured_image | img_url: '300x300' }}"
                                        alt="{{ linked_product.title }}"
                                        class="w-full h-full object-contain"
                                    />
                                    {% endif %}
                                    <div
                                    class="option-overlay absolute inset-0 bg-[#282C3780] transition-all duration-300 group-hover:bg-transparent"
                                    ></div>
                                </div>
                                <div class="w-full h-full flex flex-col gap-[2px] my-auto h-max pl-[16px]">
                                    <p class="text-[16px] font-medium">{{ variant.title }}</p>
                                    <p class="text-[16px] font-medium">€{{ variant.price | divided_by: 100 }} EUR</p>
                                </div>
                                </div>
                            {% endfor %}
                            </div>
                        </div>
                    {% endif %}
                {% endfor %}
                <!-- Bottom Section -->
                <div class="flex gap-[18px] flex-col">
                  {% comment %} <div class="border-b border-[#C8C9CC] pb-[24px]">
                    <div class="flex items-center gap-[6px] mb-[10px]">
                      <p class="text-[18px] font-medium">
                        Build and calibration + Softwares:
                      </p>
                      <p
                        id="build-selected-text"
                        class="text-[14px] font-normal text-[#C8C9CC]"
                      >
                        Yes
                      </p>
                    </div>
                    <div class="flex gap-[6px]">
                      <button
                        class="build-option text-[16px] font-medium px-[16px] py-[8px] bg-[#ffffff] text-[#2F333D] leading-[100%] transition-all duration-300"
                        data-value="Yes"
                      >
                        Yes
                      </button>
                      <button
                        class="build-option text-[16px] font-medium px-[16px] py-[8px] bg-[#2F333D] text-white leading-[100%] hover:bg-[#4A4E5A] transition-all duration-300"
                        data-value="No"
                      >
                        No
                      </button>
                    </div>
                  </div> {% endcomment %}

                  <!-- Quantity Selector -->
                  <div class="pb-[24px] border-b border-[#C8C9CC]">
                    <div class="flex items-center gap-[16px]">
                      <p class="text-[18px] font-medium">Quantity:</p>
                      <div
                        class="flex items-center gap-[19.5px] border border-[#C8C9CC] px-[10px] py-[6px] text-[#C8C9CC]"
                      >
                        <button
                          id="qty-decrease"
                          class="text-[16px] font-medium"
                        >
                          –
                        </button>
                        <p id="quantity-text" class="text-[16px] font-medium">
                          1
                        </p>
                        <button
                          id="qty-increase"
                          class="text-[16px] font-medium"
                        >
                          +
                        </button>
                      </div>
                    </div>
                  </div>

                  <!-- Price and Availability -->
                  <div class="pb-[18px]">
                    <div class="flex items-center justify-between">
                      <p id="bundle-total-price" class="product-price text-[24px] font-bold text-white">{{ product.price | money_with_currency }}</p>
                        {% if product.available %}
                        <div class="bg-[#2F6F1E] px-[9px] py-[3px]">
                            <p class="text-[12px] font-light text-white uppercase leading-[100%]">IN STOCK</p>
                        </div>
                        {% else %}
                        <div class="bg-[#8A1E1E] px-[9px] py-[3px]">
                            <p class="text-[12px] font-light text-white uppercase leading-[100%]">OUT OF STOCK</p>
                        </div>
                        {% endif %}
                      {% comment %} <div class="bg-[#2F6F1E] px-[9px] py-[3px]">
                        <p
                          class="text-[12px] font-light text-white uppercase leading-[100%]"
                        >
                          AVAILABLE ON BACKORDER
                        </p>
                      </div> {% endcomment %}
                    </div>
                  </div>

                  <!-- Add to Cart Button -->
                  <div class="pb-[24px]">
                    <button id="atc_btn" class="w-full bg-[#6EC7B3] text-[#282C37] font-bold text-[16px] py-[16px] px-[32px] hover:bg-[#5AB39F] transition-all duration-300 uppercase flex items-center justify-center gap-[16px]">
                      ADD TO CART
                      <img src="https://cdn.shopify.com/s/files/1/0976/8622/5226/files/right_arrow-white.svg?v=1761556170" alt="" />
                    </button>
                  </div>

                  <!-- Additional Information -->
                  <div class="flex flex-col gap-[16px] items-center text-center">
                    <p class="text-[14px] text-[#C8C9CC] font-normal">
                      Free delivery on qualifying orders.
                    </p>
                    <div>
                      <p
                        class="text-[14px] text-[#C8C9CC] font-normal leading-[100%]"
                      >
                        Returns fee charged. Exclusions apply.
                      </p>
                      <a
                        href="#"
                        class="text-[14px] text-[#C8C9CC] font-normal leading-[100%] underline hover:text-[#66c2a4] transition-colors"
                      >
                        View our Delivery & Returns Policy
                      </a>
                    </div>
                    <p class="text-[14px] text-[#C8C9CC] font-normal">
                      This product has shipping restrictions.
                    </p>
                  </div>
                </div>
            </div>
        </div>
      </div>
    </div>
  </div>
</section>
{% schema %}
{
    "name": "Custom Main Product",
    "settings": [],
    "blocks": [
    {
      "type": "variant_block",
      "name": "Product Variant Block",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Frame Type"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Subtitle",
          "default": "Select an option"
        },
        {
          "type": "product",
          "id": "linked_product",
          "label": "Select Product"
        }
      ]
    }
  ],
    "presets": [
        {
            "name": "Custom Main Product"
        }
    ]
}
{% endschema %}
{% comment %} <script>
document.addEventListener("DOMContentLoaded", () => {
  const atcBtn = document.getElementById("atc_btn");
  const qtyText = document.getElementById("quantity-text");

  if (!atcBtn || !qtyText) return;

  // -------------------
  // Quantity logic
  // -------------------
  let quantity = parseInt(qtyText.textContent.trim()) || 1;

  const updateQtyText = () => {
    qtyText.textContent = quantity;
  };

  const qtyIncrease = document.getElementById("qty-increase");
  const qtyDecrease = document.getElementById("qty-decrease");

  qtyIncrease?.addEventListener("click", () => {
    quantity += 1;
    updateQtyText();
  });

  qtyDecrease?.addEventListener("click", () => {
    if (quantity > 1) {
      quantity -= 1;
      updateQtyText();
    }
  });

  // -------------------
  // Variant selection logic
  // -------------------
  document.querySelectorAll(".product-options").forEach((option) => {
    option.addEventListener("click", () => {
      const parent = option.closest("[data-block-id]");
      parent.querySelectorAll(".product-options").forEach((opt) => opt.classList.remove("selected"));
      option.classList.add("selected");
    });
  });

  // -------------------
  // Add to Cart logic
  // -------------------
  atcBtn.addEventListener("click", async () => {
    const selectedOptions = document.querySelectorAll(".product-options.selected");
    const selectedVariants = [...selectedOptions].map((opt) => opt.dataset.variantId);

    const mainVariantId = {{ product.selected_or_first_available_variant.id }};
    const mainProductTitle = `{{ product.title | escape }}`;

    // Build main product
    const mainItem = {
      id: mainVariantId,
      quantity,
      properties: {
        _bundle_main: "true",
        _bundle_title: mainProductTitle,
      },
    };

    // Build child variants
    const childItems = selectedVariants.map((id) => ({
      id,
      quantity,
      properties: {
        _child_of: mainVariantId,
        _bundle_title: mainProductTitle,
      },
    }));

    const items = [mainItem, ...childItems];

    try {
      const response = await fetch("/cart/add.js", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ items }),
      });

      const data = await response.json();
      console.log("Bundle added:", data);

      window.location.href = "/cart"; // View results on cart page
    } catch (err) {
      console.error("Error adding to cart:", err);
    }
  });
});
</script> {% endcomment %}
