  });

  qtyDecrease?.addEventListener("click", () => {
    if (quantity > 1) {
      quantity -= 1;
      updateQtyText();
    }
  });

  // -------------------
  // Variant selection logic
  // -------------------
  document.querySelectorAll(".product-options").forEach((option) => {
    option.addEventListener("click", () => {
      const parent = option.closest("[data-block-id]");
      parent.querySelectorAll(".product-options").forEach((opt) => opt.classList.remove("selected"));
      option.classList.add("selected");
      updateTotalPrice();
    });
  });

  // -------------------
  // Price calculation
  // -------------------
  const mainPrice = {{ product.price | divided_by: 100 }};
  
  function updateTotalPrice() {
    const selectedOptions = document.querySelectorAll(".product-options.selected");
    let totalChildPrice = 0;

    selectedOptions.forEach(opt => {
      const price = parseFloat(opt.dataset.price || "0");
      totalChildPrice += price;
    });

    const total = (mainPrice + totalChildPrice) * quantity;
    priceDisplay.textContent = `£${total.toFixed(2)}`;
  }

  updateTotalPrice(); // initialize

  // -------------------
  // Add to Cart logic
  // -------------------
  atcBtn.addEventListener("click", async () => {
    const selectedOptions = document.querySelectorAll(".product-options.selected");

    if (!selectedOptions.length) {
      alert("Please select at least one configuration option before adding to cart.");
      return;
    }

    const mainVariantId = {{ product.selected_or_first_available_variant.id }};
    const mainProductTitle = `{{ product.title | escape }}`;
    const bundleId = `bundle-${Date.now()}`;

    const bundleDetails = [...selectedOptions].map((opt, i) => {
      return {
        index: i + 1,
        productTitle: opt.dataset.productTitle || "Child Product",
        option: opt.dataset.optionName || opt.textContent.trim(),
        variantId: parseInt(opt.dataset.variantId),
        price: parseFloat(opt.dataset.price || "0")
      };
    });

    const totalChildPrice = bundleDetails.reduce((sum, item) => sum + item.price, 0);
    const totalPrice = (mainPrice + totalChildPrice) * quantity;

    // Bundle properties
    const properties = {
      _bundle: "true",
      _bundle_id: bundleId,
      _bundle_parent_title: mainProductTitle,
      _bundle_total_price: `£${totalPrice.toFixed(2)}`
    };

    bundleDetails.forEach((item, i) => {
      properties[`Item ${i + 1}`] = `${item.productTitle} - ${item.option} (£${item.price.toFixed(2)})`;
      properties[`_bundle_item_${i}_title`] = item.productTitle;
      properties[`_bundle_item_${i}_option`] = item.option;
      properties[`_bundle_item_${i}_variant_id`] = item.variantId;
      properties[`_bundle_item_${i}_price`] = `£${item.price.toFixed(2)}`;
    });

    console.log("Adding bundle with total price:", totalPrice, "properties:", properties);

    // Build items array: parent + child variants
    const items = [
      {
        id: mainVariantId,
        quantity: quantity,
        properties: properties
      },
      ...bundleDetails.map(child => ({
        id: child.variantId,
        quantity: quantity,
        properties: {
          _child_of: mainVariantId,
          _bundle_id: bundleId,
          _bundle_parent_title: mainProductTitle
        }
      }))
    ];

    try {
      const response = await fetch("/cart/add.js", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ items })
      });

      const data = await response.json();
      console.log("Cart add response:", data);

      if (!response.ok) throw new Error(data.message || "Failed to add bundle");

      window.location.href = "/cart";
    } catch (error) {
      console.error("Error adding bundle:", error);
      alert("There was an error adding your bundle to the cart: " + error.message);
    }
  });
});
</script>


<script>
document.addEventListener("DOMContentLoaded", () => {
  const priceDisplays = document.querySelectorAll(".product-price");
  const qtyText = document.getElementById("quantity-text");
  
  if (priceDisplays.length === 0) return;

  // Get main price
  const mainPrice = {{ product.price | divided_by: 100 }};
  
  // Format price as "€80,00 EUR"
  function formatPrice(amount) {
    const formattedAmount = amount.toFixed(2).replace('.', ',');
    return `€${formattedAmount} EUR`;
  }
  
  // Update price function
  function updateTotalPrice() {
    const selectedOptions = document.querySelectorAll(".product-options.selected");
    let totalChildPrice = 0;

    // Sum all selected option prices
    selectedOptions.forEach(opt => {
      const price = parseFloat(opt.dataset.price || "0");
      totalChildPrice += price;
    });

    // Get quantity
    const quantity = parseInt(qtyText?.textContent.trim() || "1") || 1;

    // Calculate total: (main price + selected options) * quantity
    const total = (mainPrice + totalChildPrice) * quantity;
    const formattedPrice = formatPrice(total);

    // Update ALL price displays
    priceDisplays.forEach(priceDisplay => {
      priceDisplay.textContent = formattedPrice;
    });
  }

  // Initialize price
  updateTotalPrice();

  // Listen for option selection
  document.querySelectorAll(".product-options").forEach((option) => {
    option.addEventListener("click", () => {
      setTimeout(updateTotalPrice, 10);
    });
  });

  // Listen for quantity changes
  const qtyIncrease = document.getElementById("qty-increase");
  const qtyDecrease = document.getElementById("qty-decrease");
  
  if (qtyIncrease) {
    qtyIncrease.addEventListener("click", () => {
      setTimeout(updateTotalPrice, 10);
    });
  }
  
  if (qtyDecrease) {
    qtyDecrease.addEventListener("click", () => {
      setTimeout(updateTotalPrice, 10);
    });
  }
});
</script>

<script>
document.addEventListener("DOMContentLoaded", () => {
  const thumbnails = document.querySelectorAll(".product-thumbnail");
  const desktopImage = document.getElementById("product-image-desktop");
  const mobileImage = document.getElementById("product-image-mobile");

  if (thumbnails.length === 0) return;

  thumbnails.forEach((thumbnail) => {
    thumbnail.addEventListener("click", () => {
      const imageSrc = thumbnail.dataset.imageSrc;
      const imageAlt = thumbnail.dataset.imageAlt;

      // Update desktop image
      if (desktopImage) {
        desktopImage.src = imageSrc;
        desktopImage.alt = imageAlt;
      }

      // Update mobile image
      if (mobileImage) {
        mobileImage.src = imageSrc;
        mobileImage.alt = imageAlt;
      }

      // Update active thumbnail border
      thumbnails.forEach((thumb) => {
        thumb.classList.remove("border-[#6EC7B3]");
        thumb.classList.add("border-transparent");
      });
      thumbnail.classList.remove("border-transparent");
      thumbnail.classList.add("border-[#6EC7B3]");
    });
  });
});
</script>