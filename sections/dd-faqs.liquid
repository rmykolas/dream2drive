{% comment %}
FAQ Section
- Fully Tailwind CSS compatible
- Dynamic FAQ items (question + answer)
- Supports rich text answers for formatting
{% endcomment %}

<section
  class="bg-[#282C37] pt-[80px] pb-[120px] px-[16px] md:px-[32px] font-roboto-condensed"
>
  <div class="max-w-[1280px] mx-auto">
    <!-- Section Title -->
    {% if section.settings.title != blank %}
      <h2
        class="text-[60px] font-medium text-white text-center leading-[100%] mb-[10px] md:mb-[60px] uppercase"
      >
        {{ section.settings.title }}
      </h2>
    {% endif %}

    <!-- FAQ Accordion -->
    <div>
      {% for block in section.blocks %}
        <div
          class="faq-item overflow-hidden border-b-[3px] border-[#4A4E5A]"
          {{ block.shopify_attributes }}
        >
          <button
            class="w-full flex items-center justify-between py-[32px] text-left transition-colors duration-300"
            type="button"
            onclick="this.nextElementSibling.classList.toggle('max-h-0'); this.nextElementSibling.classList.toggle('max-h-[1000px]'); this.querySelector('.chevron').classList.toggle('rotate-180');"
          >
            <span
              class="button-text text-white text-[24px] font-medium leading-[100%]"
            >
              {{ block.settings.question }}
            </span>
            <div
              class="chevron min-w-[40px] min-h-[40px] flex items-center justify-center bg-[#C8C9CC] transition-all duration-300"
            >
              {% if section.settings.chevron_icon != blank %}
                <img
                  src="{{ section.settings.chevron_icon | image_url }}"
                  alt="Chevron"
                  class="transition-all duration-300"
                />
              {% else %}
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="10" viewBox="0 0 18 10" fill="none" class="transition-all duration-300">
                  <path d="M1 1L9 9L17 1" stroke="#282C37" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              {% endif %}
            </div>
          </button>

          <div
            class="faq-content overflow-hidden transition-all duration-300 ease-in-out max-h-0"
          >
            <div class="pb-[24px]">
              <p class="text-[#C8C9CC] text-[20px] leading-[120%]">
                {{ block.settings.answer }}
              </p>
            </div>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "FAQ Section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Section Title",
      "default": "FAQ"
    },
    {
      "type": "image_picker",
      "id": "chevron_icon",
      "label": "Chevron Icon (optional)"
    }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "FAQ Item",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "Who supervises BeMyBond's activities?"
        },
        {
          "type": "textarea",
          "id": "answer",
          "label": "Answer",
          "default": "The activities of the BeMyBond bond platform are supervised by the Bank of Lithuania..."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQ Section",
      "category": "Content"
    }
  ]
}
{% endschema %}
