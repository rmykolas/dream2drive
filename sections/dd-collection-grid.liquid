<!-- Header Section -->
<div class="bg-[#1C2127] py-[64px] px-[16px]">
  <div class="max-w-[1280px] mx-auto">
    <!-- Breadcrumb -->
    <div class="flex items-center justify-center gap-[8px] mb-[24px]">
      <a
        href="{{ routes.root_url }}"
        class="text-[#C8C9CC] text-[14px] hover:text-white transition-colors"
      >
        Home
      </a>
      <img
        src="https://cdn.shopify.com/s/files/1/0976/8622/5226/files/right_arrow-white.svg?v=1761556170"
        alt="arrow"
        class="w-[8px] h-[8px]"
      />
      <span class="text-[#C8C9CC] text-[14px]">
        {{ collection.title }}
      </span>
    </div>

    <!-- Main Title -->
    <h1
      class="text-[48px] md:text-[52px] font-bold text-white text-center leading-[100%] mb-[30px]"
    >
      {{ collection.title }}
    </h1>
  </div>
</div>

<!-- Collection Grid -->
<section
  class="py-[80px] px-[16px] md:px-[32px] bg-[#ECECEC] font-roboto-condensed"
>
  <div class="max-w-[1280px] mx-auto">
   <div class="flex flex-wrap max-lg:justify-center gap-[16px]">
  {% for product in collection.products %}

    <a
      href="{{ product.url }}"
      class="relative flex flex-col bg-[#2B2C37] w-full md:w-[243px] h-[360px] hover:bg-[#4A4E5A] transition-all duration-300"
    >
      <!-- Pavadinimas BLOKO VIDUJE, viršuje -->
      <h3
        class="text-white text-[18px] md:text-[20px] font-bold leading-[120%] tracking-[-0.01em] uppercase p-[12px]"
      >
        {{ product.title }}
      </h3>

      <!-- Nuotrauka, pilnai telpanti į bloką -->
      <div class="flex-1 w-full overflow-hidden flex items-center justify-center px-[10px] pb-[10px]">
        {% if product.featured_image %}
          <img
            src="{{ product.featured_image | image_url: width: 600 }}"
            alt="{{ product.title }}"
            class="w-full h-full object-contain"
          >
        {% else %}
          <div class="w-full h-full bg-[#4A4E5A] flex items-center justify-center text-white">
            No Image
          </div>
        {% endif %}
      </div>

      <!-- Kaina + VAT BLOKO VIDUJE apačioje kairėje -->
      <div class="absolute bottom-[12px] left-[16px]">
        <p class="text-white text-[20px] md:text-[22px] font-normal leading-[120%]">
          {{ product.price | money }}
        </p>
        <p class="text-[#C8C9CC] text-[12px] md:text-[13px] leading-[120%]">
          VAT included
        </p>
      </div>
    </a>

  {% else %}
    <p class="text-center text-[#0F0F0F] text-[18px] mt-[40px]">
      No products found in this collection.
    </p>
  {% endfor %}
</div>
  </div>
</section>
{% schema %}
{
  "name": "Collection Grid",
  "settings": [
  ],
  "presets": [
    {
      "name": "Collection Grid",
      "category": "Custom Sections",
    }
  ]
}
{% endschema %}